{
  "name": "virtual-space",
  "publisher": "jamiefutch",
  "displayName": "Virtual Space",
  "description": "Emulate Visual Studio's Virtual Space feature by allowing the cursor to move past the end of lines.",
  "version": "0.0.1",
  "repository": {
    "type": "git",
    "url": "https://github.com/jamiefutch/virtual-space.git"
  },
  "engines": {
    "vscode": "^1.80.0"
  },
  "categories": [
    "Other",
    "Keymaps"
  ],
  "activationEvents": [
    "onStartupFinished"
  ],
  "main": "./out/extension.js",
  "contributes": {
    "commands": [
      {
        "command": "virtualspace.toggle",
        "title": "Toggle Virtual Space"
      }
    ],
    "keybindings": [
      {
        "command": "virtualspace.moveRight",
        "key": "right",
        "when": "editorTextFocus && config.virtualspace.enabled"
      },
      {
        "command": "virtualspace.moveLeft",
        "key": "left",
        "when": "editorTextFocus && config.virtualspace.enabled"
      },
      {
        "command": "virtualspace.moveUp",
        "key": "up",
        "when": "editorTextFocus && config.virtualspace.enabled"
      },
      {
        "command": "virtualspace.moveDown",
        "key": "down",
        "when": "editorTextFocus && config.virtualspace.enabled"
      }
    ],
    "configuration": {
      "title": "Virtual Space",
      "properties": {
        "virtualspace.enabled": {
          "type": "boolean",
          "default": true,
          "description": "Enable or disable Virtual Space cursor movement."
        }
      }
    }
  },
  "scripts": {
    "vscode:prepublish": "npm run compile",
    "compile": "tsc -p ./",
    "watch": "tsc -watch -p ./",
    "pretest": "npm run compile && npm run lint",
    "lint": "eslint src --ext ts",
    "test": "node ./out/test/runTest.js"
  },
  "devDependencies": {
    "@types/vscode": "^1.80.0",
    "@types/mocha": "^10.0.1",
    "@types/node": "18.x",
    "@typescript-eslint/eslint-plugin": "^5.59.8",
    "@typescript-eslint/parser": "^5.59.8",
    "eslint": "^8.41.0",
    "glob": "^8.1.0",
    "mocha": "^10.2.0",
    "typescript": "^5.1.3",
    "@vscode/test-electron": "^2.3.2"
  }
}